                <Button mnemonicParsing="false" text="RECARGAR" />
            </children></HBox>
        <TableView prefHeight="200.0" prefWidth="200.0">
            <columns>
                <TableColumn prefWidth="75.0" text="CURP" />
                <TableColumn prefWidth="75.0" text="NOMBRE" />
                <TableColumn prefWidth="75.0" text="EDAD" />
                <TableColumn prefWidth="75.0" text="TELEFONO" />
                <TableColumn prefWidth="75.0" text="ALERGIAS" />
